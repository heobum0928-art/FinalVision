<UserControl x:Class="FinalVisionProject.UI.ShotTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FinalVisionProject.UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 툴바   //260330 hbk -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/><!-- 슬라이더 고정폭   //260331 hbk -->
                <ColumnDefinition Width="*"/>   <!-- X/Y/Gray — MainView와 동일 위치   //260331 hbk -->
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- //260406 hbk -- D-01: ShotTabView Grab 버튼 제거 (InspectionListView button_grab으로 통합) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="6,4" VerticalAlignment="Center">
                <ToggleButton x:Name="btn_editRoi" Content="Edit ROI" Width="80" FontSize="12"
                              IsEnabled="False" Click="BtnEditRoi_Click" Margin="0,0,12,0"
                              ToolTip="ROI 편집 모드 (로그인 후 활성)"/>
                <RadioButton x:Name="rb_original" Content="원본" FontSize="14"
                             IsChecked="True" Checked="Rb_ImageMode_Checked"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                <RadioButton x:Name="rb_annotated" Content="측정" FontSize="14"
                             Checked="Rb_ImageMode_Checked"
                             VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Label x:Name="label_result" Content="---" FontSize="16"
                       FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 슬라이더 — 절반 폭(120px)   //260331 hbk -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Width="120" Margin="8,2,8,2" VerticalAlignment="Center">
                <Slider x:Name="slider_scale" Value="52" Minimum="20" Maximum="200"
                        Thumb.DragStarted="Slider_DragStarted"
                        Thumb.DragCompleted="Slider_DragCompleted"
                        ValueChanged="Slider_scale_ValueChanged"
                        TickFrequency="5"/>
                <TextBlock TextAlignment="Center"
                           Text="{Binding Value, ElementName=slider_scale, StringFormat={}{0:0} %}"/>
            </StackPanel>

            <!-- X/Y/Gray — MainView label_pos와 동일 방식   //260331 hbk -->
            <Label Grid.Column="2" HorizontalContentAlignment="Right"
                   FontFamily="Consolas" FontSize="13" Foreground="#FF666666" VerticalAlignment="Center"
                   Content="{Binding CurrentPosDisplay, ElementName=canvas_shot}"/>

            <!-- Shot별 이미지 열기/삭제   //260331 hbk -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="4,4" VerticalAlignment="Center">
                <Button x:Name="btn_openImage" Content="열기" Width="52" FontSize="12"
                        Click="Btn_OpenImage_Click" Margin="0,0,4,0"
                        ToolTip="이미지 파일 열기 (Shot별 개별 지정)"/>
                <Button x:Name="btn_deleteImage" Content="삭제" Width="52" FontSize="12"
                        Click="Btn_DeleteImage_Click" Margin="0,0,8,0"
                        ToolTip="로드된 이미지 삭제"/>
                <TextBlock x:Name="tb_imagePath" FontSize="11" VerticalAlignment="Center"
                           Text="(없음)" Foreground="Gray" MaxWidth="220"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </StackPanel>
        </Grid>

        <!-- 이미지 캔버스 -->
        <ScrollViewer x:Name="sv_shot" Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="#FF303030"
                      ScrollChanged="Sv_shot_ScrollChanged">
            <local:RuntimeResizer x:Name="canvas_shot"
                                  HorizontalAlignment="Left" VerticalAlignment="Top"
                                  MouseWheel="Canvas_shot_MouseWheel">
                <Canvas.Background>
                    <ImageBrush Stretch="Fill"/>
                </Canvas.Background>
            </local:RuntimeResizer>
        </ScrollViewer>
    </Grid>
</UserControl>
